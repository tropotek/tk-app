# Docker
HTTP_PORT=80
HTTPS_PORT=443
MAILPIT_HTTP_PORT=8080
MAILPIT_SMTP_PORT=1030
DOCKER_TARGET=local

# set server name for production images
SERVER_NAME=localhost:80

APP_NAME=tk-app
APP_KEY=
APP_ENV=local
APP_DEBUG=true
APP_URL="http://localhost/"

DB_CONNECTION=sqlite
DB_DATABASE=database/storage/database.sqlite
DB_PORT=3306

MAIL_HOST=
MAIL_MAILER=smtp
MAIL_PORT=1025
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
